-- Hàm copy khi click
local function makeCopyable(label)
    label.Active = true  -- cho phép tương tác click
    
    label.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local text = label.Text
            local id = text:match("rbxassetid://%d+")  -- lấy phần rbxassetid://...
            
            if id then
                setclipboard(id)
                -- Feedback: đổi màu tạm thời
                local oldColor = label.TextColor3
                label.TextColor3 = Color3.fromRGB(100, 255, 120)
                label.Text = label.Text .. "  [COPIED!]"
                task.wait(1.2)
                label.TextColor3 = oldColor
                label.Text = text  -- reset text
            end
        end
    end)
end

makeCopyable(assetLabel)
makeCopyable(animLabel)

-- Cập nhật animation ID
local function updateAnimationIds()
    if not humanoid or not humanoid.Parent then return end
    
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then
        animLabel.Text = "AnimationId: (không tìm thấy Animator)"
        assetLabel.Text = "AssetId: —"
        return
    end
    
    local tracks = animator:GetPlayingAnimationTracks()
    if #tracks == 0 then
        animLabel.Text = "AnimationId: (không có animation đang chạy)"
        assetLabel.Text = "AssetId: —"
        return
    end
    
    -- Lấy animation mới nhất
    local track = tracks[#tracks]
    local anim = track.Animation
    
    if anim and anim.AnimationId ~= "" then
        local id = anim.AnimationId
        animLabel.Text = "AnimationId: " .. id
        assetLabel.Text = "AssetId: " .. id
    else
        animLabel.Text = "AnimationId: (không xác định)"
        assetLabel.Text = "AssetId: —"
    end
end

-- Event khi play animation mới
humanoid.AnimationPlayed:Connect(updateAnimationIds)

-- Update định kỳ (an toàn hơn vì đôi khi event miss)
task.spawn(function()
    while task.wait(1) do
        updateAnimationIds()
    end
end)

-- Update lần đầu sau khi load
task.delay(1.5, updateAnimationIds)

print("Animation ID Display đã load - click vào text để copy!")

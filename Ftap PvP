Workspace.ChildAdded:Connect(function(child)
    if child.Name == "GrabParts" then
        print("GrabParts detected")
        local success, grabPart = pcall(function()
            return child:WaitForChild("GrabPart", 2)
            :WaitForChild("WeldConstraint", 2).Part1
        end)
        if not success or not grabPart then
            print("Failed to get grabPart")
            return
        end

        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Name = FLING_VELOCITY_NAME
        bodyVelocity.Parent = grabPart

        local connection
        connection = child:GetPropertyChangedSignal("Parent"):Connect(function()
            if child.Parent == nil then
                local isRightMouseHeld = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

                local humanoid = plr.Character and plr.Character:FindFirstChild("Humanoid")
                local inAir = humanoid and humanoid.FloorMaterial == Enum.Material.Air

                print("Trigger check | SuperFling:", superFlingEnabled, "| RightMouse:", isRightMouseHeld, "| AirGrab:", AirGrabEnabled, "| InAir:", inAir)

                if superFlingEnabled and (isRightMouseHeld or (AirGrabEnabled and inAir)) then
                    print("FLING ACTIVATED with power:", flingStrength)
                    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    bodyVelocity.Velocity = Workspace.CurrentCamera.CFrame.LookVector * flingStrength
                else
                    print("FLING NOT TRIGGERED")
                    bodyVelocity.MaxForce = Vector3.zero
                end

                Debris:AddItem(bodyVelocity, 1)

                if connection then
                    connection:Disconnect()
                end
            end
        end)
    end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if not SilentAim then return end
    if input.KeyCode == Enum.KeyCode.Q then
        aiming = true
        print("Aiming started")
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Q then
        aiming = false
        print("Aiming stopped")
    end
end)

RunService.RenderStepped:Connect(function()
    if not SilentAim then return end
    local target = getClosestPlayerToCenter()
    currentTarget = target
    updateHighlight(target)

    if aiming and currentTarget and currentTarget.Character then
        local torso = currentTarget.Character:FindFirstChild("Torso")
        if torso then
            camera.CFrame = CFrame.new(camera.CFrame.Position, torso.Position)
        end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    if not antiGrabEnabled then return end
    if v:IsA("Explosion") then
        v.BlastPressure = 0
        print("Explosion neutralized")
    end
end)

BeingHeld.Changed:Connect(function(C)
    if not antiGrabEnabled then return end
    if C == true then
        print("Player is being held, triggering anti-grab")
        local char = Player.Character
        if BeingHeld.Value == true then
            local Event
            Event = R.RenderStepped:Connect(function()
                if BeingHeld.Value == true then
                    char["HumanoidRootPart"].AssemblyLinearVelocity = Vector3.new()
                    StruggleEvent:FireServer(Player)
                else
                    print("Released from grab")
                    Event:Disconnect()
                end
            end)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.F then
        if not AirGrabEnabled then
            Notify("Air Grab", "Air Grab is OFF", 2)
            return
        end

        superFlingEnabled = true

        if not airGrabCustomMode then
            originalFlingStrength = flingStrength
            airGrabCustomMode = true
            usingCustomPower = true
            flingStrength = 250

            Notify("Air Grab", "Activated (Power: 250)", 2)
            return
        end

        usingCustomPower = not usingCustomPower

        if usingCustomPower then
            flingStrength = 250
            Notify("Air Grab", "Power set to 250", 2)
        else
            flingStrength = originalFlingStrength
            Notify("Air Grab", "Power restored", 2)
        end
    end
end)
